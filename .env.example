# ══════════════════════════════════════════════════════════════════
# このファイルはテンプレートです。実際の値は .env.local に書いてください。
# .env.local は .gitignore で除外済み — 絶対にコミットしないこと！
# ══════════════════════════════════════════════════════════════════

# ── Firebase Admin SDK（サーバー側・秘密鍵）────────────────────────────────
# Firebase Console → プロジェクト設定 → サービスアカウント → 新しい秘密鍵を生成
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXX\n-----END PRIVATE KEY-----\n"

# ── Firebase クライアント SDK（ブラウザ側・公開可）────────────────────────
# Firebase Console → プロジェクト設定 → 全般 → マイアプリ → SDK の設定と構成
PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXX
PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your-project-id
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# ── FCM プッシュ通知（VAPID鍵）──────────────────────────────────────────────
# Firebase Console → プロジェクト設定 → Cloud Messaging → ウェブの設定 → 鍵ペアを生成
PUBLIC_FIREBASE_VAPID_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── 管理者設定 ───────────────────────────────────────────────────────────────
# カンマ区切りで Firebase の UID を指定（Firebase Auth のコンソールで確認）
ADMIN_UIDS=uid1,uid2

# ── Vercel Cron 認証トークン ────────────────────────────────────────────────
# openssl rand -hex 24 などで生成したランダム文字列
CRON_SECRET=your-random-secret-here
